# framework_multiagentes — Environment variables
# Setup: cp .env.example .env — then fill in your keys

# ── LLM Provider (required) ──────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here   # optional — for Claude Sonnet

# ── Postgres — The Ledger (structured data) ──────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agentkit
POSTGRES_USER=agentkit
POSTGRES_PASSWORD=agentkit

# ── Qdrant — The Memory (vector store for RAG) ───────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=agentkit_docs

# ── LangFuse — Observability (traces, costs) ─────────────
LANGFUSE_SECRET_KEY=sk-lf-your-key-here
LANGFUSE_PUBLIC_KEY=pk-lf-your-key-here
LANGFUSE_HOST=http://localhost:3000

# ── Tavily — Web search tool ─────────────────────────────
# TAVILY_API_KEY=tvly-your-key-here        # optional — only for web_search tool

# ── Chainlit UI ──────────────────────────────────────────
CHAINLIT_HOST=0.0.0.0
CHAINLIT_PORT=8000
